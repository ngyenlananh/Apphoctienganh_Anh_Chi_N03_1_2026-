{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "my_mobile_app",
            "request": "launch",
            "type": "dart",
            "args": [
                "--web-port",
                "5000"
            ]
        },
        {
            "name": "my_mobile_app (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "my_mobile_app (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}